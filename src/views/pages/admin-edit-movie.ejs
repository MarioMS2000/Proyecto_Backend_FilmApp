<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= movie.title %></title>
</head>
<body>
  <form action="<%= `/admin/movies/${movie.id}` %>" method="post">
    <label for="title">Title</label>
    <input type="text" name="title" value="<%= movie.title %>">
    <label for="poster">Image</label>
    <input type="text" name="poster" value="<%= movie.poster %>">
    <label for="year">Year</label>
    <input type="text" name="year" value="<%= movie.year %>">
    <label for="director">Director</label>
    <input type="text" name="director" value="<%= movie.director %>">
    <label for="genre">Genre</label>
    <input type="text" name="genre" value="<%= movie.genre %>">
    <label for="duration">Duration</label>
    <input type="text" name="duration" value="<%= movie.duration %>">
    <label for="plot">Plot</label>
    <textarea name="plot" ><%= movie.plot %></textarea>
    <button type="submit">Edit</button>
  </form>
</body>
</html>
