<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= pageTitle %></title>
    <link rel="stylesheet" href="/css/style.css" />
  </head>
  <body>
    <h1><%= movie.title %></h1>
    <p>Detalle de película</p>
    <a href="/movies">Volver</a>
    <main>
      <img src="<%= movie.poster %>" width="200" />
      <p>Año: <%= movie.year %></p>
      <p>Director: <%= movie.director %></p>
      <p>Género: <%= movie.genre %></p>
      <p>Duración: <%= movie.duration %></p>
      <p>Plot: <%= movie.plot %></p>
      <p>Actores: <%= Array.isArray(movie.actors) ? movie.actors.join(", ") : movie.actors %></p>
      <p>Rating: <%= movie.rating %></p>

      <form action="/favorites" method="POST">
        <input type="hidden" name="sourceType" value="<%= movie.sourceType %>">
        <input type="hidden" name="sourceMovieId" value="<%= movie.imdbID %>">
        <button type="submit">Guardar favorito</button>
      </form>
    
      <h2>Reviews</h2>
    
      <% if (reviewsError) { %>
        <p><%= reviewsError %></p>
        <% } else if(!movie.reviews || movie.reviews.length===0) { %>
        <p>No hay reviews</p>
      <% } else { %>
          <% movie.reviews.forEach(review=> { %>
            <section>
              <p>Autor: <%= review.author %></p>
              <p>Rating: <%= review.rating %></p>
              <p><%= review.review %></p>
            </section>
          <% }) %>
        <% } %>
    </main>
  </body>
</html>
