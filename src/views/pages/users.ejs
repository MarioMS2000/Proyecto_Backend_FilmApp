<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Administrar usuarios</title>
    <link rel="stylesheet" href="/css/style.css" />
  </head>
  <body>
    <%- include("../partials/nav", { user }) %>

    <main class="page-shell">
      <section class="page-heading split">
        <div>
          <span class="landing-kicker">Admin</span>
          <h1>Usuarios</h1>
          <p>Cambia roles y elimina usuarios no administradores.</p>
        </div>
        <a class="landing-button landing-button-primary" href="/admin/users/new">Crear usuario</a>
      </section>

      <section class="table-panel">
        <table>
          <thead>
            <tr>
              <th>Nombre</th>
              <th>Email</th>
              <th>Rol</th>
              <th>Acciones</th>
            </tr>
          </thead>
          <tbody>
            <% users.forEach(account => { %>
              <tr>
                <td><%= account.name %></td>
                <td><%= account.email %></td>
                <td>
                  <form class="inline-form" action="/admin/users/<%= account.id %>/role" method="POST">
                    <select name="role" aria-label="Rol de <%= account.name %>">
                      <option value="user" <%= account.role === "user" ? "selected" : "" %>>user</option>
                      <option value="admin" <%= account.role === "admin" ? "selected" : "" %>>admin</option>
                    </select>
                    <button class="small-button" type="submit">Guardar</button>
                  </form>
                </td>
                <td>
                  <% if (account.role !== "admin") { %>
                    <form action="/admin/users/<%= account.id %>/delete" method="POST">
                      <button class="small-button danger" type="submit">Eliminar</button>
                    </form>
                  <% } else { %>
                    <span class="muted">Protegido</span>
                  <% } %>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </section>
    </main>
  </body>
</html>
