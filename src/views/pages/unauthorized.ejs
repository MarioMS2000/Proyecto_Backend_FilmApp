<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Unauthorized</title>
    <link rel="stylesheet" href="/css/style.css" />
  </head>
  <body>
    <main class="auth-shell">
      <section class="auth-card">
        <span class="eyebrow">Unauthorized</span>
        <h1><%= title %></h1>
        <p><%= message %></p>

        <div class="link-row">
          <a class="primary-button" href="/login">Ir a login</a>
          <a class="ghost-button" href="<%= returnTo %>">Intentar de nuevo</a>
          <a class="chip-link" href="/">Volver al inicio</a>
        </div>
      </section>
    </main>
  </body>
</html>
