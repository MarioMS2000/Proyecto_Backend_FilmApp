<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Login</title>
    <link rel="stylesheet" href="/css/style.css" />
  </head>
  <body>
    <main class="auth-shell">
      <section class="auth-card">
        <span class="landing-kicker">Acceso</span>
        <h1>Inicia sesion</h1>
        <p class="auth-copy">Entra para seguir explorando peliculas y acceder a tus vistas privadas.</p>

        <form class="auth-form" action="/api/login" method="post">
          <label for="email">
            Email
            <input type="text" name="email" id="email" required>
          </label>

          <label for="password">
            Password
            <input type="password" name="password" id="password" required>
          </label>

          <button class="landing-button landing-button-primary" type="submit">Entrar</button>
        </form>

        <% if (message) { %>
          <p class="auth-message"><%= message %></p>
        <% } %>

        <div class="auth-links">
          <a class="landing-button landing-button-secondary" href="/signup">Registrarse</a>
          <a class="landing-button landing-button-secondary" href="/">Volver</a>
        </div>
      </section>
    </main>
  </body>
</html>
