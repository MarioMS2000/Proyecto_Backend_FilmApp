<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Favoritos</title>
    <link rel="stylesheet" href="/css/style.css" />
  </head>
  <body>
    <h1>Favoritos</h1>

    <p>Usuario: <%= user?.name || "Usuario" %></p>

    <% if (message) { %>
      <p><%= message %></p>
    <% } %>

    <h2>Lista de favoritos</h2>

    <% if (favorites && favorites.length > 0) { %>
      <ul>
        <% favorites.forEach(favorite => { %>
          <li>
            <p><strong>ID favorito:</strong> <%= favorite.id %></p>
            <p><strong>Origen:</strong> <%= favorite.sourceType %></p>
            <p><strong>ID pelicula:</strong> <%= favorite.sourceMovieId %></p>

            <form action="/favorites/<%= favorite.id %>/delete" method="POST">
              <button type="submit">Eliminar</button>
            </form>
          </li>
        <% }) %>
      </ul>
    <% } else { %>
      <p>No tienes favoritos guardados.</p>
    <% } %>
  </body>
</html>
