<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Favoritos</title>
    <link rel="stylesheet" href="/css/style.css" />
  </head>
  <body>
    <h1>Favoritos</h1>

    <p>Usuario: <%= user?.name || "Usuario" %></p>

    <% if (message) { %>
      <p><%= message %></p>
    <% } %>

    <h2>Añadir favorito</h2>
    <form action="/favorites" method="POST">
      <div>
        <label for="sourceType">Origen:</label>
        <select name="sourceType" id="sourceType" required>
          <option value="">Selecciona una opción</option>
          <option value="OMDB">OMDB</option>
          <option value="MONGO">MONGO</option>
        </select>
      </div>

      <div>
        <label for="sourceMovieId">ID de la película:</label>
        <input
          type="hidden"
          id="sourceMovieId"
          name="sourceMovieId"
          value=¨teste¨
          required
        />
      </div>

      <button type="submit">Guardar en favoritos</button>
    </form>

    <h2>Lista de favoritos</h2>

    <% if (favorites && favorites.length > 0) { %>
      <ul>
        <% favorites.forEach(favorite => { %>
          <li>
            <p><strong>ID favorito:</strong> <%= favorite.id %></p>
            <p><strong>Origen:</strong> <%= favorite.sourceType %></p>
            <p><strong>ID película:</strong> <%= favorite.sourceMovieId %></p>

            <form action="/favorites/<%= favorite.id %>/delete" method="POST">
              <button type="submit">Eliminar</button>
            </form>
          </li>
        <% }) %>
      </ul>
    <% } else { %>
      <p>No tienes favoritos guardados.</p>
    <% } %>
  </body>
</html>

