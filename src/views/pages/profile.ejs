<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Perfil</title>
    <link rel="stylesheet" href="/css/style.css" />
  </head>
  <body>
    <%- include("../partials/nav", { user }) %>

    <main class="page-shell narrow">
      <section class="page-heading">
        <span class="landing-kicker">Cuenta</span>
        <h1>Perfil</h1>
        <p>Revisa tus datos y cambia tu contraseña.</p>
      </section>

      <section class="panel">
        <dl class="profile-list">
          <div>
            <dt>Nombre</dt>
            <dd><%= user.name %></dd>
          </div>
          <div>
            <dt>Email</dt>
            <dd><%= user.email %></dd>
          </div>
          <div>
            <dt>Rol</dt>
            <dd><%= user.role %></dd>
          </div>
        </dl>
      </section>

      <section class="panel">
        <h2>Cambiar contraseña</h2>

        <% if (message) { %>
          <p class="notice"><%= message %></p>
        <% } %>

        <form class="stacked-form" action="/profile/password" method="POST">
          <label for="password">Contraseña actual</label>
          <input type="password" name="password" id="password" required>

          <label for="newPassword">Nueva contraseña</label>
          <input type="password" name="newPassword" id="newPassword" required>

          <label for="newPassword2">Confirmar contraseña</label>
          <input type="password" name="newPassword2" id="newPassword2" required>

          <input type="hidden" name="id" value="<%= user.id %>">
          <button class="landing-button landing-button-primary" type="submit">Actualizar contraseña</button>
        </form>
      </section>
    </main>
  </body>
</html>
